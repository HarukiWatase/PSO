% 1. 研究背景と目的 (ヘッダー帯)
% ============================================================
\begin{beamercolorbox}[wd=\textwidth, sep=0.4cm, leftskip=0.5em]{block title}
    \usebeamerfont{block title}\strut 1. 研究背景と目的
